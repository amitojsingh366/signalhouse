# Copy to .env and fill in your values

# Discord bot (optional — leave empty to skip bot startup)
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
DISCORD_GUILD_ID=

# Anthropic API key (required for /upload screenshot parsing)
ANTHROPIC_API_KEY=your_anthropic_api_key

# PostgreSQL
POSTGRES_PASSWORD=trader

# Database URL (used by api and bot containers — default works with docker-compose)
# DATABASE_URL=postgresql+asyncpg://trader:trader@postgres:5432/trader

# Web dashboard API URL
# - For Caddy-based local/non-local runs, keep this empty to use same-origin /api via proxy.
# - If you intentionally bypass Caddy, set an absolute API origin (e.g. http://localhost:8000).
# NEXT_PUBLIC_API_URL=
# Web server port (used by web container, local host mapping, and Caddy upstream)
WEB_PORT=3000

# Caddy host ports (published on the machine running Docker)
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443

# Local Caddy HTTP host port (used by docker-compose.local.yml)
CADDY_LOCAL_HTTP_PORT=3000

# APNs push notifications (optional — for iOS app VoIP calls)
# Place your AuthKey.p8 file in config/ directory
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=
APNS_SANDBOX=false

# Caddy domain (used in Caddyfile)
# DOMAIN=yourdomain.com

# Authentication (passkey / WebAuthn)
JWT_SECRET=generate-a-random-secret-here
# WEBAUTHN_RP_NAME=signalhouse
# Passkey RP ID is derived from DOMAIN:
# - production: set DOMAIN to your public hostname
# - local self-hosting: set DOMAIN=localhost
# Optional comma-separated list of extra allowed origins for WebAuthn verify.
# If unset, defaults include https://<DOMAIN>, http://localhost:3000, http://localhost:8000.
# If using custom local Caddy HTTP port, include it here (e.g. http://localhost:2004).
# WEBAUTHN_EXPECTED_ORIGINS=https://yourdomain.com

# NOTE:
# docker-compose.yml now forwards all variables above to the relevant containers.
