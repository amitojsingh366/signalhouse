# Copy to .env and fill in your values

# Discord bot (required)
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_CHANNEL_ID=your_channel_id
DISCORD_GUILD_ID=your_server_id

# Anthropic API key (required for /upload screenshot parsing)
ANTHROPIC_API_KEY=your_anthropic_api_key

# PostgreSQL
POSTGRES_PASSWORD=trader

# Database URL (used by api and bot containers — default works with docker-compose)
# DATABASE_URL=postgresql+asyncpg://trader:trader@postgres:5432/trader

# Web dashboard API URL (for Next.js rewrites — default works with docker-compose)
# NEXT_PUBLIC_API_URL=http://api:8000

# APNs push notifications (optional — for iOS app VoIP calls)
# Place your AuthKey.p8 file in config/ directory
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=net.amitoj.trader
APNS_SANDBOX=false

# Authentication (passkey / WebAuthn)
JWT_SECRET=generate-a-random-secret-here
# WEBAUTHN_RP_ID=yourdomain.com
# WEBAUTHN_RP_NAME=Trader
