# Copy to .env and fill in your values

# Discord bot (required)
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_CHANNEL_ID=your_channel_id
DISCORD_GUILD_ID=your_server_id

# Ollama (screenshot parsing — runs as a Docker service, default URL works with docker-compose)
# OLLAMA_URL=http://ollama:11434

# PostgreSQL
POSTGRES_PASSWORD=trader

# Database URL (used by api and bot containers — default works with docker-compose)
# DATABASE_URL=postgresql+asyncpg://trader:trader@postgres:5432/trader

# Web dashboard API URL (for Next.js rewrites — default works with docker-compose)
# NEXT_PUBLIC_API_URL=http://api:8000
