yourdomain.com {
	# Caddy serves HTTPS with a self-signed cert (internal CA).
	# Cloudflare (Full mode) terminates public SSL and connects here on 443.
	tls internal

	# API endpoints — proxy to FastAPI
	handle /api/* {
		reverse_proxy api:8000
	}

	# Everything else — proxy to Next.js
	handle {
		reverse_proxy web:3000
	}
}
