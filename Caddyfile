:80 {
	# HTTP — redirect or serve (Cloudflare Flexible mode)
	handle /api/* {
		reverse_proxy api:8000
	}
	handle {
		reverse_proxy web:3000
	}
}

:443 {
	# HTTPS — Cloudflare Full mode connects here.
	# Use Caddy's internal CA for a self-signed cert (works with CF Full, not Full Strict).
	tls internal

	handle /api/* {
		reverse_proxy api:8000
	}
	handle {
		reverse_proxy web:3000
	}
}
