:80 {
	# Cloudflare terminates SSL — Caddy serves plain HTTP on port 80.
	# CF connects to origin on port 80 (Flexible mode) or 443 (Full mode).

	# API endpoints — proxy to FastAPI
	handle /api/* {
		reverse_proxy api:8000
	}

	# Everything else — proxy to Next.js
	handle {
		reverse_proxy web:3000
	}
}
