{$DOMAIN:localhost} {
	# Apple app-site-association for passkeys (Associated Domains)
	handle /.well-known/apple-app-site-association {
		header Content-Type application/json
		respond `{"webcredentials":{"apps":["{$APPLE_TEAM_ID:XXXXXXXXXX}.net.amitoj.Trader"]}}`
	}

	# API endpoints — proxy to FastAPI
	handle /api/* {
		reverse_proxy api:8000
	}

	# Everything else — proxy to Next.js
	handle {
		reverse_proxy web:{$WEB_PORT:3000}
	}
}
