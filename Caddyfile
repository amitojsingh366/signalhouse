yourdomain.com {
	# Caddy auto-HTTPS (Let's Encrypt).
	# Cloudflare proxied — Caddy likely has a cached cert from initial setup.

	# Upload endpoint — longer timeout for vision model processing
	handle /api/upload/* {
		reverse_proxy api:8000 {
			transport http {
				response_header_timeout 300s
			}
		}
	}

	# API endpoints — proxy to FastAPI
	handle /api/* {
		reverse_proxy api:8000
	}

	# Everything else — proxy to Next.js
	handle {
		reverse_proxy web:3000
	}
}
